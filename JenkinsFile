pipeline {
    agent any
    environment {
        AWS_REGION = 'ap-south-1'
    }
    stages {
        stage('Checkout') {
            steps { checkout scm }
        }
        stage('Install') {
            steps {
                sh '''
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install -r requirements.txt
                '''
            }
        }
        stage('Test') {
            steps {
                sh '''
                    . venv/bin/activate
                    pytest -q
                '''
            }
        }
        stage('Deploy') {
            steps {
                sh '''
                    aws ssm send-command \
                      --document-name "AWS-RunShellScript" \
                      --targets "Key=tag:Role,Values=flask-app" \
                      --comment "Deploy flask app" \
                      --parameters commands='["cd /home/appuser/app","git pull origin main","pip3 install -r requirements.txt --break-system-packages","systemctl restart flaskapp"]' \
                      --region $AWS_REGION
                '''
            }
        }
    }
}