#!/bin/bash
set -euxo pipefail
exec > /var/log/user-data.log 2>&1   # everything logged here for debugging

# --- 1. Swap first (t3.micro has only 1 GB RAM; Jenkins needs the headroom) ---
if [ ! -f /swapfile ]; then
  dd if=/dev/zero of=/swapfile bs=1M count=2048
  chmod 600 /swapfile
  mkswap /swapfile
  swapon /swapfile
  echo '/swapfile swap swap defaults 0 0' >> /etc/fstab
fi

# --- 2. Jenkins repo + key ---
wget -O /etc/yum.repos.d/jenkins.repo https://pkg.jenkins.io/redhat-stable/jenkins.repo
rpm --import https://pkg.jenkins.io/redhat-stable/jenkins.io-2023.key

# --- 3. Install Java 21 (current Jenkins LTS requires it), Jenkins, git, python ---
dnf install -y java-21-amazon-corretto jenkins git python3 python3-pip

# --- 4. Pin Jenkins to Java 21 + move temp dir off the RAM-backed /tmp ---
mkdir -p /var/lib/jenkins/tmp
chown jenkins:jenkins /var/lib/jenkins/tmp
mkdir -p /etc/systemd/system/jenkins.service.d
cat > /etc/systemd/system/jenkins.service.d/override.conf <<'EOF'
[Service]
Environment="JAVA_HOME=/usr/lib/jvm/java-21-amazon-corretto"
Environment="JENKINS_JAVA_CMD=/usr/lib/jvm/java-21-amazon-corretto/bin/java"
Environment="JAVA_OPTS=-Djava.io.tmpdir=/var/lib/jenkins/tmp"
EOF

# --- 5. Start ---
systemctl daemon-reload
systemctl enable --now jenkins